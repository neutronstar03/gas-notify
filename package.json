{
  "name": "gas-notify",
  "type": "module",
  "version": "1.0.4",
  "private": true,
  "bin": {
    "gas-notify": "./legacy-shell/cli.ts"
  },
  "scripts": {
    "start": "bun run legacy-shell/cli.ts",
    "dev": "bun --watch run legacy-shell/cli.ts",
    "extension:build": "bunx vite build --config vite.extension.config.ts",
    "extension:watch": "bunx vite build --watch --config vite.extension.config.ts",
    "check": "bunx tsc --noEmit",
    "validate:rpcs": "bun run scripts/validate-rpcs.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "toasted-notifier": "^10.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@types/bun": "latest",
    "@types/chrome": "^0.1.39",
    "eslint": "^10.0.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.7"
  }
}
