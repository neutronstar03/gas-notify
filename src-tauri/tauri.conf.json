{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gas Notify",
  "version": "0.1.0",
  "identifier": "com.gasnotify.tray",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run desktop:frontend",
    "beforeBuildCommand": "bun run desktop:build:ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gas Notify",
        "width": 220,
        "height": 108,
        "minWidth": 220,
        "minHeight": 108,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
