{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./config.schema.json",
  "title": "Gas Notify Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Editor-only JSON Schema reference."
    },
    "thresholdGwei": {
      "type": "number",
      "minimum": 0,
      "description": "Single-threshold shorthand. Use thresholds[] for multiple named thresholds."
    },
    "direction": {
      "$ref": "#/$defs/direction",
      "description": "Default direction for thresholdGwei or thresholds missing direction."
    },
    "hysteresisGwei": {
      "type": "number",
      "minimum": 0,
      "description": "Default hysteresis for thresholds missing hysteresisGwei."
    },
    "hysteresisPercent": {
      "type": "number",
      "minimum": 0,
      "default": 5,
      "description": "Default percentage-based hysteresis when hysteresisGwei is not set."
    },
    "thresholds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/threshold"
      }
    },
    "cooldownSeconds": {
      "type": "number",
      "minimum": 0,
      "default": 180
    },
    "reconnectBaseDelayMs": {
      "type": "number",
      "minimum": 0,
      "default": 2000
    },
    "reconnectMaxDelayMs": {
      "type": "number",
      "minimum": 0,
      "default": 30000
    },
    "httpPollIntervalMs": {
      "type": "number",
      "minimum": 1000,
      "default": 12000
    },
    "wsRetryWhilePollingMs": {
      "type": "number",
      "minimum": 1000,
      "default": 60000
    },
    "rpcRequestTimeoutMs": {
      "type": "number",
      "minimum": 1000,
      "default": 12000
    },
    "preferredRpcs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rpcEndpoint"
      },
      "description": "Primary WebSocket endpoints."
    },
    "fallbackRpcs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rpcEndpoint"
      },
      "description": "HTTP fallback endpoints."
    },
    "notificationTitle": {
      "type": "string",
      "default": "Ethereum Base Fee"
    },
    "appId": {
      "type": "string",
      "default": "GasNotify.BaseFee"
    },
    "silentNotifications": {
      "type": "boolean",
      "default": false
    },
    "notifyOnStartupState": {
      "type": "boolean",
      "default": false
    },
    "logLevel": {
      "enum": ["debug", "info", "warn", "error"],
      "default": "info"
    },
    "logFilePath": {
      "type": "string",
      "description": "Optional log file path relative to the repo root or absolute."
    },
    "stateFilePath": {
      "type": "string",
      "default": "data/state.json"
    },
    "notifyOnRecovery": {
      "type": "boolean",
      "default": true
    },
    "notifyOnRpcFailover": {
      "type": "boolean",
      "default": true
    },
    "snoreToastPath": {
      "type": "string",
      "default": "vendor/SnoreToast.exe"
    }
  },
  "$defs": {
    "direction": {
      "enum": ["below", "above", "both"]
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gwei"],
      "properties": {
        "name": {
          "type": "string"
        },
        "gwei": {
          "type": "number",
          "minimum": 0
        },
        "direction": {
          "$ref": "#/$defs/direction"
        },
        "hysteresisGwei": {
          "type": "number",
          "minimum": 0
        },
        "hysteresisPercent": {
          "type": "number",
          "minimum": 0
        },
        "cooldownSeconds": {
          "type": "number",
          "minimum": 0
        },
        "message": {
          "type": "string"
        }
      }
    },
    "rpcEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "anyOf": [
    {
      "required": ["thresholds"]
    },
    {
      "required": ["thresholdGwei"]
    }
  ]
}
